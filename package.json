{
  "name": "pos-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev:next": "next dev",
    "dev:matcher": "dotnet run --project fingerprint-matcher/FingerprintMatcher -c Release",
    "dev:matcher:5051": "set ASPNETCORE_URLS=http://127.0.0.1:5051&& dotnet run --project fingerprint-matcher/FingerprintMatcher -c Release",
    "dev:5051": "concurrently -k -n next,matcher -c cyan,magenta \"npm run dev:next\" \"npm run dev:matcher:5051\"",
    "dev": "concurrently -k -n next,matcher -c cyan,magenta \"npm run dev:next\" \"npm run dev:matcher\"",
    "build:matcher": "dotnet publish fingerprint-matcher/FingerprintMatcher -c Release -o fingerprint-matcher/publish",
    "start:matcher": "dotnet fingerprint-matcher/publish/FingerprintMatcher.dll",
    "build": "npx prisma generate && next build --webpack",
    "start": "next start",
    "lint": "next lint",
    "db:reset": "prisma db push --force-reset && node prisma/seed-admin.js",
    "generate": "prisma generate",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@digitalpersona/core": "^0.2.6",
    "@digitalpersona/devices": "^0.2.6",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mui/icons-material": "^7.3.4",
    "@mui/lab": "^7.0.1-beta.18",
    "@mui/material": "^7.3.4",
    "@mui/material-nextjs": "^7.3.9",
    "@prisma/client": "^6.17.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.9.0",
    "html2canvas": "^1.4.1",
    "jsonwebtoken": "^9.0.3",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.545.0",
    "next": "^16.0.7",
    "node-fetch": "^3.3.2",
    "pngjs": "^7.0.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "twilio": "^5.13.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/pngjs": "^6.0.5",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "^16.0.7",
    "prisma": "^6.17.1",
    "tailwindcss": "^4"
  }
}
